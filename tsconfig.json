{
  "compilerOptions": {
    "baseUrl": "./src",
    "rootDir": "./src",
    "declaration": true,
    "esModuleInterop": true,
    "lib": ["esnext"],
    "module": "es2020",
    "moduleResolution": "node16",
    "noImplicitReturns": true,
    "resolveJsonModule": true,
    "strict": true,
    "target": "ES2019",
    "useUnknownInCatchVariables": false
  }
}
